# WhatsApp group chat ID (get this from bridge logs on first connection)
GROUP_CHAT_ID=your-group-id@g.us

# Flask
FLASK_PORT=5001

# Node.js bridge
BRIDGE_URL=http://localhost:3000

# Database
DB_PATH=data/punter_bot.db

# Timezone
TIMEZONE=Europe/Dublin

# Admin phone numbers (WhatsApp format: country+number@c.us)
ADMIN_PHONE=353...@c.us
SUPERADMIN_PHONE=353...@c.us

# Test mode (enables prefix parsing: "Kev: pick text")
TEST_MODE=false
